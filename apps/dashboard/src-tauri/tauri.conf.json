{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart (Components) Toolkit Widget",
  "version": "0.0.4",
  "identifier": "no.tiwas.homeytoolbox.dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Smart (Components) Toolkit Widget",
        "width": 320,
        "height": 480,
        "minWidth": 260,
        "minHeight": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": false
      },
      {
        "label": "toast",
        "url": "toast.html",
        "title": "",
        "width": 560,
        "height": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://cdn.athom.com; connect-src 'self' https://api.athom.com https://*.athom.com wss://*.athom.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
