{
  "id": "clg_pause",
  "title": {
    "en": "Pause circadian light group",
    "no": "Pause dognrytme-lysgruppe"
  },
  "hint": {
    "en": "Pauses automatic adjustments. Use amount 0 to pause until resumed manually.",
    "no": "Pauser automatiske justeringer. Bruk 0 for pause til manuell gjenopptakelse."
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=circadian-light-group"
    },
    {
      "type": "number",
      "name": "amount",
      "title": { "en": "Amount", "no": "Mengde" },
      "placeholder": { "en": "10", "no": "10" }
    },
    {
      "type": "dropdown",
      "name": "unit",
      "title": { "en": "Unit", "no": "Enhet" },
      "values": [
        { "id": "seconds", "label": { "en": "Seconds", "no": "Sekunder" } },
        { "id": "minutes", "label": { "en": "Minutes", "no": "Minutter" } },
        { "id": "hours", "label": { "en": "Hours", "no": "Timer" } }
      ]
    }
  ],
  "titleFormatted": {
    "en": "Pause for [[amount]] [[unit]]",
    "no": "Pause i [[amount]] [[unit]]"
  }
}
